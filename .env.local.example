# ============================================================
# .env.local.example （一人用版）
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ★追加★ サービスロールキー（一人用でRLSを通さず書き込むのに必要）
# Supabase → Project Settings → API → service_role key
# 絶対に公開しないこと（NEXT_PUBLIC_ を付けない＝ブラウザに出ない）
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Gemini（無料枠: 1日1,500リクエスト）
# 取得先: aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...

# Anthropic（削除済み・不要）
# ANTHROPIC_API_KEY=sk-ant-...

# ★任意★ 固定ユーザーID（未設定なら既定値が使われる）
# APP_USER_ID=00000000-0000-0000-0000-000000000001

# ★任意★ 今月の予算（円）。「今月あと○円使える」の基準。未設定なら 100000
# MONTHLY_BUDGET=100000

# ★任意★ Google Calendar 連携
# セットアップ方法: node scripts/google-auth.mjs <CLIENT_ID> <CLIENT_SECRET>
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_REFRESH_TOKEN=1//xxx
# GOOGLE_CALENDAR_ID=primary
